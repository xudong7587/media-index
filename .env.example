MEDIA_USER=admin
MEDIA_PASS=change-me

TMDB_API_KEY=
QAS_BASE_URL=http://your-qas-host:your-qas-port
QAS_TOKEN=
PANSOU_URL=http://your-pansou-host:your-pansou-port
PANSOU_CONCURRENCY=32
PANSOU_SEARCH_TIMEOUT_SECONDS=45

CLOUD_SAVE_PATH=/strm
LOCAL_SAVE_PATH=/downloads
CATEGORY_PATHS_JSON={"movie":"/movie","tv":"/tv","variety":"/tv"}
WISHLIST_CRON_ENABLED=false
WISHLIST_CRON_SCHEDULE=0 */6 * * *
DB_PATH=/app/data/media_index.db
STATIC_DIR=/app/frontend
CACHE_DIR=/app/data/cache
TMDB_DISCOVER_CACHE_TTL_SECONDS=21600
TMDB_DETAILS_CACHE_TTL_SECONDS=86400
TMDB_TRACKING_CACHE_TTL_SECONDS=3600
TMDB_GENRES_CACHE_TTL_SECONDS=604800
TRACKING_SCHEDULER_ENABLED=true
TRACKING_POLL_MINUTES=5
TRACKING_CHECK_HOUR=10
TRACKING_MAX_RETRIES=5
TRACKING_TIMEZONE=Asia/Shanghai
